rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /organizations/{organizationId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.organizationId == organizationId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
